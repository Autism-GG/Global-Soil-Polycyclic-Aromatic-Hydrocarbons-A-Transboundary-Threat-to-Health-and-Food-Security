import rasterio
import numpy as np
import os

def subtract_rasters(path1, path2, output_path):
    # Ensure output directory exists
    output_dir = os.path.dirname(output_path)
    if not os.path.exists(output_dir):
        os.makedirs(output_dir)

    with rasterio.open(path1) as src1:
        data1 = src1.read(1)
        meta = src1.meta

    with rasterio.open(path2) as src2:
        data2 = src2.read(1)

    # Perform subtraction: 585 - 126
    # Use float32 type to avoid integer overflow and support NaN
    result = data1.astype(np.float32) - data2.astype(np.float32)

    # Update metadata
    meta.update(dtype=rasterio.float32, count=1)

    with rasterio.open(output_path, 'w', **meta) as dst:
        dst.write(result, 1)

    print(f"Calculation successful! Result saved at: {output_path}")

# --- Set file paths here ---
if __name__ == "__main__":
    file_585 = 'XXX.tif'
    file_126 = 'XXX.tif'
    file_out = 'XXX.tif'

    subtract_rasters(file_585, file_126, file_out)
