    '0-50': (0, 50),
    '50-100': (50, 100),
    '100-1000': (100, 1000),
    '>1000': (1000, float('inf'))
}


def adjust_continent_by_map(country_name, original_continent, continent_map, manual_fixes):
    """
    Adjust country's continent based on manual mapping table
    """
    # First check manual fixes list
    if country_name in manual_fixes:
        return manual_fixes[country_name]

    # Then check user-defined mapping
    if country_name in continent_map:
        new_continent = continent_map[country_name]
        if new_continent != original_continent:
            print(f"  📍 Adjustment: {country_name} from '{original_continent}' to '{new_continent}'")
        return new_continent

    return original_continent


