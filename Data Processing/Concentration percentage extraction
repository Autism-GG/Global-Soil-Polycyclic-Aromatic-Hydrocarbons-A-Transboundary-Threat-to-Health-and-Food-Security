# Concentration range definitions (ug/kg) - defined in log10 space
CONCENTRATION_RANGES = {
    '0-50': (float('-inf'), np.log10(50)),
    '50-100': (np.log10(50), np.log10(100)),
    '100-1000': (np.log10(100), np.log10(1000)),
    '>1000': (np.log10(1000), float('inf'))
}

