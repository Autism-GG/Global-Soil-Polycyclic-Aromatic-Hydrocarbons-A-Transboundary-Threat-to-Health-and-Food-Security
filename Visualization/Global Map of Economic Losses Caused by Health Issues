# Read your own shapefile
# Replace "your_shapefile.shp" with your shapefile path and filename
your_sf <- st_read("XXX.shp", stringsAsFactors = FALSE)

# View field names to identify the name field
print(names(your_sf))

# Extract region names - adjust field name based on your shapefile
# If the name field is not "NAME_ENG", modify to the correct field name
#region_names <- sort(your_sf$NAME) # Modify field name if needed
#write.csv(region_names, "region_names.csv")

# Read sample information
economic_loss <- read.xlsx("global_male_economic_loss.xlsx")
head(economic_loss)

# Add HMT information - adjust field name based on your shapefile
your_sf$Total_Cost <- economic_loss$Total_Cost[match(your_sf$NAME, economic_loss$Country)] # Modify field name if needed

# Create base map
world <- ggplot(your_sf) +
  geom_sf(aes(fill = Total_Cost), color = "gray50", size = 0.2) +
  scale_fill_gradient(
    low = "#F6F6F8",   # Lowest value color
    high = "#82ADD0",  # Highest value color
    na.value = "gray90" # Gray for unmatched regions
  ) +
  theme_minimal() +
  labs(x = NULL, y = NULL) +
  theme(
    panel.grid = element_blank(),
    panel.border = element_blank()
  )

world
