create_final_plot <- function(top_plot, right_plot) {
  layout <- top_plot + plot_spacer() + 
    combined_plot + right_plot +
    plot_layout(
      ncol = 2, nrow = 2,
      widths = c(4, 1),  # Main plot:right plot = 4:1
      heights = c(1, 4)  # Top plot:main plot = 1:4
    )  
  wrap_elements(full = layout) +
    theme(plot.margin = margin(5, 5, 5, 5))
}

