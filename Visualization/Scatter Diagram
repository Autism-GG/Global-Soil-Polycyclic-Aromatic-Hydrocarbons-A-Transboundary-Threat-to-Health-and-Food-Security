format_p_value <- function(p) {
  if (p < 0.001) {  
    return("< 0.001")
    } else if (p < 0.01) { 
      return("< 0.01")
      } else if (p < 0.05) { 
        return("< 0.05")
        } else { 
          return(paste0("= ", format(round(p,3), nsmall =3)))
        }
}

get_density_range <- function(data, variable) {
  densities <- data %>% 
    group_by(Group) %>% 
    group_map(~density(.x[[variable]], na.rm =TRUE)$y) %>% 
    unlist()
  return(range(densities, na.rm =TRUE)) 
}

calculate_unified_count_range <- function(data, variable_x, variable_y, bins = 20) {
  x_counts <- data %>%
    group_by(Group) %>%
    group_map(~ hist(.x[[variable_x]], breaks = seq(min(data[[variable_x]]), max(data[[variable_x]]), length.out = bins + 1), plot = FALSE)$counts) %>%
    unlist()
  y_counts <- data %>%
    group_by(Group) %>%
    group_map(~ hist(.x[[variable_y]], breaks = seq(min(data[[variable_y]]), max(data[[variable_y]]), length.out = bins + 1), plot = FALSE)$counts) %>%
    unlist()
  max_count <- max(c(x_counts, y_counts), na.rm = TRUE) * 1.1
  return(c(0, max_count))}

# Calculate correlation coefficients
cor_data <- long_data %>%
  group_by(Group) %>%
  summarize(
    r_value = round(cor(X, Y),3), 
    p_value_raw = cor.test(X, Y)$p.value,
    p_value_formatted = format_p_value(p_value_raw)
    ) %>%
  mutate(
    legend_label = Group, 
    stat_label = paste0(Group,": R = ", r_value,", p ", p_value_formatted) # Final annotation text
    )# Merge statistical results back to main data
long_data <- long_data %>%
  left_join(cor_data, by = "Group")

# Original data range
x_range <- range(long_data$X, na.rm = TRUE)
y_range <- range(long_data$Y, na.rm = TRUE)
# Function to expand range (add 10% margin)
expand_range <- function(r) {
  range_diff <- diff(r)
  return(c(r[1] -0.1* range_diff,r[2] +0.1* range_diff))}
# Final expanded ranges
expanded_x_range <- expand_range(x_range)
expanded_y_range <- expand_range(y_range)

x_pos <- expanded_x_range[1] + 0.01 * diff(expanded_x_range) # 2% position on X axis
n_groups <- nrow(cor_data)
# Number of groups
y_spacing <-0.08*diff(expanded_y_range)
# Vertical spacing between group annotations# Assign Y-axis positions by group order (top to bottom)
cor_data <- cor_data %>%
  arrange(Group) %>%
  mutate(
    y_pos = expanded_y_range[2] - (0:(n_groups-1)) * y_spacing -0.02*diff(expanded_y_range)
    )

# 1. Main scatter plot theme (with axes, border, bold text)
