  theme(
    plot.title = element_text(hjust =0.5, face ="bold", size =16), # Centered bold title
    axis.title = element_text(face ="bold", size =14),
    # Bold axis labels
    axis.text = element_text(size =12, face ="bold", color ="black"),# Bold axis ticks
    axis.ticks = element_line(color ="black", linewidth =0.5),
    # Axis tick lines
    axis.ticks.length = unit(0.2,"cm"), 
    # Tick length
    legend.position ="none",
    # Hide legend (annotations already include group info)
    panel.grid.major = element_blank(),
    # Hide major grid lines
    panel.grid.minor = element_blank(),
    # Hide minor grid lines
    plot.background = element_rect(fill ="white", color = NA),
    # White background
    panel.border = element_rect(color ="black", fill = NA, linewidth =1) # Plot border
    )# 2. Marginal plot theme (no axes, no grid, reduced margins)
no_axis_theme <- theme_void() +
  theme(
    legend.position ="none",
    plot.background = element_rect(fill ="white", color = NA),
    plot.margin = margin(0,0,0,0),
    panel.grid.major = element_blank(),
    panel.grid.minor = element_blank()
    )# 3. Color scheme (3 groups default, adjust based on number of groups)
sci_colors <- c('#7b95c6','#ED949A')[1:length(unique(long_data$Group))]# Axis labels (replace with your variable names)
